<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AB Workday Widget"
            android:textSize="26sp"
            android:textStyle="bold" />
			
		<TextView
			android:id="@+id/widgetHint"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:text="Dodajte widget na začetni zaslon (Home screen → Widgets → AB Workday Widget)."
			android:textSize="16sp"/>	
			
		<Button
			android:id="@+id/openWidgetsButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Odpri widgete"
			android:layout_marginTop="10dp"/>			

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Začetni datum: 2.3.2026"
            android:textSize="18sp" />

        <Button
            android:id="@+id/pickDateButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Izberi datum" />

        <RadioGroup
            android:id="@+id/radioGroupAB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Začetni dan je A" />

            <RadioButton
                android:id="@+id/radioB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Začetni dan je B" />
        </RadioGroup>
		<EditText
			android:id="@+id/prefixEdit"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:hint="Besedilo pred A/B/X"/>	
<TextView
    android:id="@+id/shiftText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Zamik cikla: 0"
    android:textSize="18sp"
    android:layout_marginTop="20dp"/>

<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <Button
        android:id="@+id/shiftMinus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-1"/>

    <Button
        android:id="@+id/shiftPlus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+1"/>

</LinearLayout>			

        <Switch
            android:id="@+id/switchWeekends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Preskoči vikende" />

        <Switch
            android:id="@+id/switchHolidays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Preskoči dela proste dni" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shrani" />

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Osveži widget" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>