<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeFragmentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/previewWeekNavigator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/previousPreviewWeekButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_preview_previous_week"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back_24"
                    app:layout_constraintBottom_toBottomOf="@id/previewWeekTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/previewWeekTitle"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/previewWeekTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/nextPreviewWeekButton"
                    app:layout_constraintStart_toEndOf="@id/previousPreviewWeekButton"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/nextPreviewWeekButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_preview_next_week"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_forward_24"
                    app:layout_constraintBottom_toBottomOf="@id/previewWeekTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/previewWeekTitle"
                    app:tint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/previewTodayButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_preview_today"
                    android:padding="8dp"
                    android:src="@drawable/ic_home_24"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@id/previewWeekTitle"
                    app:layout_constraintStart_toEndOf="@id/previousPreviewWeekButton"
                    app:layout_constraintTop_toTopOf="@id/previewWeekTitle"
                    app:tint="?attr/colorOnSurfaceVariant" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.dante.workcycle.ui.ClickableRecyclerView
                android:id="@+id/previewRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:nestedScrollingEnabled="false" />

            <LinearLayout
                android:id="@+id/widgetPromptContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widgetHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openWidgetsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/open_widgets"
                    app:icon="@drawable/ic_widgets_24"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="?attr/colorOnPrimary" />
            </LinearLayout>

            <include layout="@layout/include_cycle_section" />
            <include layout="@layout/include_rules_section" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.7"
                android:text=""
                android:textSize="12sp" />

            <TextView
                android:id="@+id/githubLinkText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/github"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/saveBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="10dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/revertButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/revert"
                android:textAllCaps="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/save"
                android:textAllCaps="false"
                app:icon="@drawable/ic_save_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorOnPrimary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
