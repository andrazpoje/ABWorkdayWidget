<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dayCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="88dp"
    android:foreground="?attr/selectableItemBackground"
    android:transitionName="calendarDayCard">

    <FrameLayout
        android:id="@+id/dayCardFrame"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/dayContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="4dp"
            android:paddingTop="5dp"
            android:paddingEnd="4dp"
            android:paddingBottom="5dp">

            <TextView
                android:id="@+id/dayNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="@string/calendar_day_number_placeholder" />

            <TextView
                android:id="@+id/dayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/calendar_day_label_placeholder"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/secondaryContainer"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/secondaryIcon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    app:tint="@android:color/white"
                    android:visibility="gone" />

                <View
                    android:id="@+id/secondaryDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_label_color_circle"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/secondaryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxWidth="52dp"
                    android:maxLines="1"
                    android:paddingStart="6dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="2dp"
                    android:text="@string/calendar_secondary_label_placeholder"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/statusIconsContainer"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="invisible">

                <ImageView
                    android:id="@+id/statusIconFirst"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@null"
                    android:padding="1dp"
                    android:visibility="gone"
                    app:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/statusIconSecond"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:padding="1dp"
                    android:visibility="gone"
                    app:tint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
