<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/workLogWidgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_classic"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/workLogWidgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/work_log_widget_title"
        android:textAllCaps="true"
        android:textColor="#CCFFFFFF"
        android:includeFontPadding="false"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/workLogWidgetStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/work_log_widget_status_placeholder"
        android:textColor="#FFFFFFFF"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/workLogWidgetPrimaryValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/work_log_widget_primary_placeholder"
        android:textColor="#F2FFFFFF"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/workLogWidgetSecondaryValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/work_log_widget_secondary_placeholder"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/workLogWidgetTertiaryValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/work_log_widget_tertiary_placeholder"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp" />

</LinearLayout>
