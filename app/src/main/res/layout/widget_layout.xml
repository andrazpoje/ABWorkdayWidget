<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AA000000"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/leftColorBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="10dp"
        android:background="#FFFFFF"
        android:orientation="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/prefixText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/todayLabelText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/abText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="A"
            android:textColor="#FFFFFF"
            android:textSize="60sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/extraDaysContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day1Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day1Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day1Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day2Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day2Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day2Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day3Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day3Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day3Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day4Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day4Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day4Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day5Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day5Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day5Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/day6Dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="8dp"
                    android:background="#FFFFFF"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/day6Title"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/day6Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>