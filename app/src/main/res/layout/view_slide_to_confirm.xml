<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSlideTrack"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imageSlideLeadingIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_work_time_24"
                app:tint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/textSlideLabel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="72dp"
                android:paddingEnd="72dp"
                android:textSize="17sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSlideHandle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardCornerRadius="28dp"
        app:cardElevation="3dp">

        <ImageView
            android:id="@+id/imageSlideHandleIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_forward_24"
            app:tint="?attr/colorOnPrimary" />
    </com.google.android.material.card.MaterialCardView>

</merge>
