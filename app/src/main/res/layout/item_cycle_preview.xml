<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <!-- LEVO: DAN + DATUM -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dayTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Tor." />

            <TextView
                android:id="@+id/dayDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                tools:text="7. apr. 2026" />
        </LinearLayout>

        <!-- SREDINA: ASSIGNMENT -->
        <LinearLayout
            android:id="@+id/assignmentContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/viewSecondaryIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone"
                tools:src="@drawable/ic_assignment_vacation_24"
                tools:visibility="visible" />

            <View
                android:id="@+id/viewSecondaryDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_label_color_circle"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/daySecondaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Dopust"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- DESNO: CIKEL -->
        <TextView
            android:id="@+id/dayCycleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="A" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>