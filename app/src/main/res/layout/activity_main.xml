<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
			android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold" />

		<TextView
			android:id="@+id/todayStatusText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textSize="28sp"
			android:textStyle="bold"
			android:layout_marginTop="16dp"
			android:layout_gravity="center_horizontal"/>
			
		<TextView
			android:id="@+id/widgetHint"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:text="@string/widget_not_added"
			android:textSize="16sp"/>	
			
		<Button
			android:id="@+id/openWidgetsButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/open_widgets"
			android:layout_marginTop="10dp"/>

		<Button
			android:id="@+id/checkDateButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/check_date"/>

		<TextView
			android:id="@+id/dateResultText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textSize="20sp" />

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
			android:text="@string/start_date_label"
            android:textSize="18sp" />

        <Button
            android:id="@+id/pickDateButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
			android:text="@string/select_date" />

        <RadioGroup
            android:id="@+id/radioGroupAB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
				android:text="@string/start_day_a" />

            <RadioButton
                android:id="@+id/radioB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
				android:text="@string/start_day_b" />
        </RadioGroup>
		<EditText
			android:id="@+id/prefixEdit"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:text="@string/prefix_text"/>
<TextView
    android:id="@+id/shiftText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
	android:text="@string/cycle_shift_label"
    android:textSize="18sp"
    android:layout_marginTop="20dp"/>

<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <Button
        android:id="@+id/shiftMinus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-1"/>

    <Button
        android:id="@+id/shiftPlus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+1"/>

</LinearLayout>

		<com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchWeekends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
			android:text="@string/skip_weekends" />

		<com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchHolidays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
			android:text="@string/skip_holidays" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/saveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
				android:text="@string/save" />

            <Button
                android:id="@+id/refreshButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
				android:text="@string/refresh" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>