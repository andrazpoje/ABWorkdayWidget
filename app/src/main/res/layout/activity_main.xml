<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/main"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingStart="20dp"
		android:paddingTop="20dp"
		android:paddingEnd="20dp"
		android:paddingBottom="72dp">

		<RelativeLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="12dp">

			<TextView
				android:id="@+id/appTitle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_centerVertical="true"
				android:letterSpacing="0.03"
				android:text="@string/app_name"
				android:textSize="22sp"
				android:textStyle="bold" />

			<ImageButton
				android:id="@+id/settingsButton"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:layout_alignParentEnd="true"
				android:layout_centerVertical="true"
				android:background="?attr/selectableItemBackgroundBorderless"
				android:contentDescription="@string/settings"
				android:padding="8dp"
				android:src="@android:drawable/ic_menu_preferences"
				android:tint="?attr/colorOnSurface" />
		</RelativeLayout>

		<com.google.android.material.card.MaterialCardView
			android:id="@+id/statusCard"
			android:layout_width="match_parent"
			android:layout_height="180dp"
			android:layout_marginBottom="16dp"
			android:clickable="true"
			android:focusable="true"
			android:foreground="?attr/selectableItemBackground"
			app:cardCornerRadius="20dp"
			app:cardElevation="6dp"
			app:cardUseCompatPadding="true">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical"
				android:padding="20dp">

				<TextView
					android:id="@+id/statusTitle"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:alpha="0.85"
					android:text="@string/status_section"
					android:textColor="@color/statusTextOnCard"
					android:textSize="14sp"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/todayStatusText"
					android:layout_width="match_parent"
					android:layout_height="0dp"
					android:layout_weight="1"
					android:gravity="center"
					android:letterSpacing="0.02"
					android:textColor="@color/statusTextOnCard"
					android:textSize="44sp"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/tomorrowStatusText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:alpha="0.95"
					android:gravity="center"
					android:textColor="@color/statusTextOnCard"
					android:textSize="18sp"
					android:textStyle="bold" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>

		<TextView
			android:id="@+id/previewTitle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:text="@string/preview_title"
			android:textSize="16sp"
			android:textStyle="bold" />

		<androidx.recyclerview.widget.RecyclerView
			android:id="@+id/previewRecyclerView"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:nestedScrollingEnabled="false" />

		<LinearLayout
			android:id="@+id/widgetPromptContainer"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:orientation="vertical"
			android:visibility="gone">

			<TextView
				android:id="@+id/widgetHint"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp" />

			<Button
				android:id="@+id/openWidgetsButton"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/open_widgets" />
		</LinearLayout>

		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cycleHeader"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			android:foreground="?attr/selectableItemBackground"
			app:cardCornerRadius="14dp"
			app:cardElevation="3dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:padding="16dp">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/cycle_section"
					android:textSize="18sp"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/cycleArrow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="▼"
					android:textSize="18sp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>

		<LinearLayout
			android:id="@+id/cycleSection"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:gravity="center_horizontal"
			android:orientation="vertical">

			<TextView
				android:id="@+id/dateText"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp"
				android:text="@string/start_date" />

			<Button
				android:id="@+id/pickDateButton"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:text="@string/select_date" />

			<TextView
				android:id="@+id/cycleDaysLabel"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/cycle_section"
				android:textSize="16sp"
				android:textStyle="bold" />

			<EditText
				android:id="@+id/cycleDaysEdit"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:hint="A,B,C,D"
				android:inputType="text"
				android:maxLines="1" />

			<TextView
				android:id="@+id/cycleDaysHint"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:text="@string/cycle_days_hint"
				android:textSize="12sp" />

			<TextView
				android:id="@+id/firstCycleDayLabel"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/first_cycle_day_label"
				android:textSize="16sp"
				android:textStyle="bold" />

			<EditText
				android:id="@+id/firstCycleDayEdit"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:hint="A"
				android:inputType="text"
				android:maxLength="20"
				android:maxLines="1" />

			<TextView
				android:id="@+id/firstCycleDayHint"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/first_cycle_day_hint"
				android:textSize="12sp" />
		</LinearLayout>

		<com.google.android.material.card.MaterialCardView
			android:id="@+id/rulesHeader"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			android:foreground="?attr/selectableItemBackground"
			app:cardCornerRadius="14dp"
			app:cardElevation="3dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:padding="16dp">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/rules_section"
					android:textSize="18sp"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/rulesArrow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="▼"
					android:textSize="18sp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>

		<LinearLayout
			android:id="@+id/rulesSection"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:gravity="center_horizontal"
			android:orientation="vertical">

			<com.google.android.material.switchmaterial.SwitchMaterial
				android:id="@+id/switchSaturdays"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/skip_saturdays"
				app:useMaterialThemeColors="true" />

			<com.google.android.material.switchmaterial.SwitchMaterial
				android:id="@+id/switchSundays"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/skip_sundays"
				app:useMaterialThemeColors="true" />

			<com.google.android.material.switchmaterial.SwitchMaterial
				android:id="@+id/switchHolidays"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/skip_holidays"
				app:useMaterialThemeColors="true" />

			<TextView
				android:id="@+id/rulesInfoText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:alpha="0.7"
				android:text="@string/rules_info_text"
				android:textSize="12sp" />
		</LinearLayout>

		<com.google.android.material.card.MaterialCardView
			android:id="@+id/displayHeader"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			android:foreground="?attr/selectableItemBackground"
			app:cardCornerRadius="14dp"
			app:cardElevation="3dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:padding="16dp">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/display_section"
					android:textSize="18sp"
					android:textStyle="bold" />

				<TextView
					android:id="@+id/displayArrow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="▼"
					android:textSize="18sp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>

		<LinearLayout
			android:id="@+id/displaySection"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:orientation="vertical">

			<EditText
				android:id="@+id/prefixEdit"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:hint="@string/prefix_text"
				android:inputType="text" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/display_section"
				android:textSize="18sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/displayInfoText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="16dp"
				android:text="@string/display_info_text"
				android:textSize="12sp" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp"
				android:text="@string/color_theme"
				android:textSize="16sp"
				android:textStyle="bold" />

			<RadioGroup
				android:id="@+id/themeGroup"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:orientation="vertical">

				<RadioButton
					android:id="@+id/themeClassic"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/theme_classic" />

				<RadioButton
					android:id="@+id/themePastel"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/theme_pastel" />

				<RadioButton
					android:id="@+id/themeDark"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/theme_dark" />
			</RadioGroup>
		</LinearLayout>

		<Button
			android:id="@+id/checkDateButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:text="@string/check_date" />

		<TextView
			android:id="@+id/dateResultText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="20dp"
			android:textSize="20sp" />

		<Button
			android:id="@+id/saveButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="10dp"
			android:text="@string/save" />

		<TextView
			android:id="@+id/githubLinkText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal"
			android:layout_marginBottom="10dp"
			android:background="?attr/selectableItemBackgroundBorderless"
			android:clickable="true"
			android:focusable="true"
			android:paddingStart="8dp"
			android:paddingTop="6dp"
			android:paddingEnd="8dp"
			android:paddingBottom="6dp"
			android:text="@string/github_project"
			android:textColor="@android:color/holo_blue_dark" />

		<TextView
			android:id="@+id/versionText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal"
			android:alpha="0.7"
			android:text="v1.1"
			android:textSize="12sp" />
	</LinearLayout>
</ScrollView>