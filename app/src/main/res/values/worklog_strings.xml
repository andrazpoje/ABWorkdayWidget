    <string name="work_log_help_title">Work Log Help</string>
    <string name="work_log_help_intro_title">How Work Log works</string>
    <string name="work_log_help_intro_body">Work Log keeps track of your daily work session, breaks, meals, notes, widget summary, and active notification in one place.</string>
    <string name="work_log_help_start_finish_title">Start and finish work</string>
    <string name="work_log_help_start_finish_body">Use Start work to begin a session and Finish work to close it. The dashboard then updates the current state, daily total, and balance for the day.</string>
    <string name="work_log_help_break_title">Breaks</string>
    <string name="work_log_help_break_body">Break marks the start of a pause, and the same action returns you to work. Break timing is reflected on the dashboard and in the active notification when available.</string>
    <string name="work_log_help_meal_notes_title">Meals and notes</string>
    <string name="work_log_help_meal_notes_body">Meal logs a meal event for the day. Note lets you attach a short text note to the current day so context is preserved in Recent Events.</string>
    <string name="work_log_help_recent_events_title">Recent Events editing</string>
    <string name="work_log_help_recent_events_body">Tap an event in Recent Events to edit its date or time. The app validates the timeline before saving so event order stays safe and meaningful.</string>
    <string name="work_log_help_widget_notification_title">Widget and notification</string>
    <string name="work_log_help_widget_notification_body">The Work Log widget shows a quick summary for today. The active notification appears while work is running and updates automatically for work and break states when notification permission is enabled.</string>
