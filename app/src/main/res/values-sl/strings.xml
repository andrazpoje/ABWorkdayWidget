    <!-- HELP -->
    <string name="help_title">Pomoč</string>
    <string name="help_getting_started_title">Kako začeti</string>
    <string name="help_getting_started_content">1. Nastavi začetni datum.\n2. Izberi prvi dan cikla.\n3. Nastavi pravila preskakovanja in oznake.\n4. Shrani spremembe.\n5. Dodaj widget na domači zaslon.</string>
    <string name="help_calculation_title">Kako deluje izračun cikla</string>
    <string name="help_calculation_content">Izbrani začetni datum je referenčna točka cikla. Prvi dan cikla je oznaka, dodeljena temu datumu. Cikel napreduje samo na vključenih dnevih. Preskočeni vikendi in prazniki cikla ne premaknejo naprej.</string>
    <string name="help_presets_title">Predloge</string>
    <string name="help_presets_content">Predloge samodejno izpolnijo polja cikla z vnaprej določenimi vrednostmi. Če cikel nato ročno spremeniš, se predloga spremeni v Po meri.</string>
    <string name="help_widget_title">Widget</string>
    <string name="help_widget_content">Widget lahko dodaš prek izbire widgetov na domačem zaslonu. Widget se samodejno posodablja in uporablja shranjene nastavitve aplikacije. Slog widgeta vpliva samo na videz.</string>
    <string name="help_faq_title">Pogosta vprašanja</string>
    <string name="help_faq_content">Zakaj se cikel na nekatere dni ne spremeni?\nKer so lahko vikendi ali prazniki preskočeni.\n\nZakaj je widget drugačen kot aplikacija?\nPreveri shranjene nastavitve in slog widgeta.\n\nZakaj obvestila ne delujejo?\nPreveri, ali so obvestila omogočena in ali je dovoljenje odobreno.</string>

