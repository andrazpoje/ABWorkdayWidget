    <string name="work_log_help_title">Pomoč za delovni čas</string>
    <string name="work_log_help_intro_title">Kako deluje evidenca dela</string>
    <string name="work_log_help_intro_body">Evidenca dela združuje dnevno delovno sejo, odmore, malico, opombe, povzetek v gradniku in aktivno obvestilo na enem mestu.</string>
    <string name="work_log_help_start_finish_title">Začetek in zaključek dela</string>
    <string name="work_log_help_start_finish_body">Uporabi Začetek dela za začetek seje in Zaključek dela za njen konec. Nadzorna plošča nato posodobi stanje, skupni čas in saldo za trenutni dan.</string>
    <string name="work_log_help_break_title">Odmori</string>
    <string name="work_log_help_break_body">Odmor označi začetek pavze, ista akcija pa te vrne nazaj na delo. Čas odmora se pokaže na nadzorni plošči in v aktivnem obvestilu, če je to omogočeno.</string>
    <string name="work_log_help_meal_notes_title">Malica in opombe</string>
    <string name="work_log_help_meal_notes_body">Malica zabeleži dogodek malice za trenutni dan. Opomba doda kratko besedilo, ki ostane vidno v seznamu zadnjih dogodkov.</string>
    <string name="work_log_help_recent_events_title">Urejanje zadnjih dogodkov</string>
    <string name="work_log_help_recent_events_body">Tapni dogodek v seznamu zadnjih dogodkov za urejanje datuma ali ure. Pred shranjevanjem aplikacija preveri časovni potek, da vrstni red dogodkov ostane smiseln.</string>
    <string name="work_log_help_widget_notification_title">Gradnik in obvestilo</string>
    <string name="work_log_help_widget_notification_body">Gradnik evidence dela prikaže hiter povzetek za danes. Aktivno obvestilo se prikaže med delom in se samodejno posodablja za delo in odmor, ko je dovoljenje za obvestila omogočeno.</string>
